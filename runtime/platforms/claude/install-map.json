{
  "platform": "claude",
  "defaultProfile": "claude-only",
  "targetRoot": "~/.claude",
  "mappings": [
    {
      "sources": [
        { "component": "shared-root", "path": "runtime/HARNESS.md" },
        { "component": "claude-platform", "path": "runtime/platforms/claude/CLAUDE.base.md" }
      ],
      "target": "CLAUDE.md",
      "mode": "concat"
    },
    {
      "component": "shared-agents",
      "source": "runtime/agents",
      "target": "agents"
    },
    {
      "component": "shared-skills",
      "source": "runtime/skills",
      "target": "skills"
    },
    {
      "component": "shared-commands",
      "source": "runtime/commands",
      "target": "commands"
    },
    {
      "component": "shared-rules",
      "source": "runtime/rules",
      "target": "rules"
    }
  ]
}

{
  "platform": "claude",
  "targetRoot": "~/.claude",
  "mappings": [
    {
      "sources": [
        "runtime/HARNESS.md",
        "runtime/platforms/claude/CLAUDE.base.md"
      ],
      "target": "CLAUDE.md",
      "mode": "concat"
    },
    {
      "source": "runtime/agents",
      "target": "agents",
      "mode": "directory"
    },
    {
      "source": "runtime/skills",
      "target": "skills",
      "mode": "directory"
    },
    {
      "source": "runtime/commands",
      "target": "commands",
      "mode": "directory"
    },
    {
      "source": "runtime/rules",
      "target": "rules",
      "mode": "directory"
    }
  ]
}

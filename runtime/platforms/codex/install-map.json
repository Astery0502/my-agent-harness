{
  "platform": "codex",
  "targetRoot": "~/.codex",
  "mappings": [
    {
      "sources": [
        "runtime/HARNESS.md",
        "runtime/platforms/codex/AGENTS.supplement.md"
      ],
      "target": "AGENTS.md",
      "mode": "concat"
    },
    {
      "source": "runtime/platforms/codex/config.base.toml",
      "target": "config.toml",
      "mode": "platform-base"
    },
    {
      "source": "runtime/platforms/codex/agents",
      "target": "agents",
      "mode": "directory"
    },
    {
      "source": "runtime/agents",
      "target": "shared-agents",
      "mode": "directory"
    },
    {
      "source": "runtime/skills",
      "target": "skills",
      "mode": "directory"
    },
    {
      "source": "runtime/commands",
      "target": "prompts",
      "mode": "directory"
    },
    {
      "source": "runtime/rules",
      "target": "rules",
      "mode": "directory"
    }
  ]
}

{
  "platform": "codex",
  "defaultProfile": "codex-only",
  "targetRoot": "~/.codex",
  "mappings": [
    {
      "sources": [
        { "component": "shared-root", "path": "runtime/HARNESS.md" },
        { "component": "codex-platform", "path": "runtime/platforms/codex/AGENTS.supplement.md" }
      ],
      "target": "AGENTS.md",
      "mode": "concat"
    },
    {
      "component": "codex-platform",
      "source": "runtime/platforms/codex/config.base.toml",
      "target": "config.toml"
    },
    {
      "component": "shared-agents",
      "source": "runtime/agents",
      "target": "shared-agents"
    },
    {
      "component": "shared-skills",
      "source": "runtime/skills",
      "target": "skills"
    },
    {
      "component": "shared-commands",
      "source": "runtime/commands",
      "target": "commands"
    },
    {
      "component": "shared-commands",
      "source": "runtime/commands",
      "target": "prompts"
    },
    {
      "component": "shared-rules",
      "source": "runtime/rules",
      "target": "rules"
    }
  ]
}
